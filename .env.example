# ─── DXZ Automation Web — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── OpenAI (required) ─────────────────────────────────────────────────────────
# Used for the AI fallback in the chat widget when no FAQ match is found.
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Upstash Redis (recommended for production) ────────────────────────────────
# Enables persistent sliding-window rate limiting across serverless instances.
# Without these, the /api/chat route allows all requests (no rate limiting).
# Create a free Redis database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>
